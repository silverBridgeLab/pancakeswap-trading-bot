# ─── BNB Smart Chain RPC ─────────────────────────────────────────────────────
# HTTP or WebSocket. Dedicated providers handle burst block fetches better than
# free public endpoints when scanning LOOKBACK_BLOCKS with full transactions.
RPC_URL_BSC=https://bsc-dataseed.binance.org

# ─── Leaders to watch ────────────────────────────────────────────────────────
# Space or comma separated. Only these EOAs trigger decode + mirror logic.
# Use addresses you study for research — not an endorsement to copy trade them.
LEADER_ADDRESSES=0x0000000000000000000000000000000000000000

# ─── Watcher cadence ─────────────────────────────────────────────────────────
# How often we poll chain head (ms). Lower = fresher signals, more RPC load.
POLL_INTERVAL_MS=4000

# Blocks to scan from head on startup and when catching up after lag (1–500).
LOOKBACK_BLOCKS=40

# ─── Follower sizing (basis-point style integers) ────────────────────────────
# scaledAmount = leaderAmount × SIZE_NUMERATOR_BP / SIZE_DENOMINATOR_BP
# Example: 1500 / 10000 = mirror 15% of the leader's input amount.
SIZE_NUMERATOR_BP=1500
SIZE_DENOMINATOR_BP=10000

# ─── Execution ───────────────────────────────────────────────────────────────
# dry-run     → log intents only (safe default)
# live-stub   → integration hook — implement signing in src/executor/liveStub.ts
EXECUTION_MODE=dry-run

# Set to 1 or true for verbose trace logging.
VERBOSE_LOGS=0
