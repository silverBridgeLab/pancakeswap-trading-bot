# BNB Chain JSON-RPC — use a reputable provider with reasonable rate limits.
RPC_URL_BSC=https://bsc-dataseed.binance.org

# Space or comma-separated EVM addresses whose router swaps you want to mimic.
LEADER_ADDRESSES=0x0000000000000000000000000000000000000000

# How often we double-check tails if block events stall (milliseconds).
POLL_INTERVAL_MS=4000

# Intent sizing ratio: numerator / denominator expressed in basis points style integers.
SIZE_NUMERATOR_BP=1500
SIZE_DENOMINATOR_BP=10000

# dry-run prints what would execute; live-stub logs hooks for wiring a signer.
EXECUTION_MODE=dry-run

# Optional: richer trace logging.
VERBOSE_LOGS=0

# How far back from chain head we hydrate on startup (helps after restarts).
LOOKBACK_BLOCKS=40
